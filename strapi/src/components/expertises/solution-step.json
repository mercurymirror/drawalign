{
  "collectionName": "components_expertises_solution_steps",
  "info": {
    "displayName": "Solution Step",
    "icon": "bulletList"
  },
  "options": {},
  "attributes": {
    "badge_label": {
      "type": "string",
      "required": true
    },
    "badge_variant": {
      "type": "enumeration",
      "default": "primary",
      "enum": [
        "primary",
        "secondary",
        "accent"
      ]
    },
    "title": {
      "type": "string"
    },
    "items": {
      "type": "component",
      "component": "elements.list-item",
      "repeatable": true
    },
    "revelation": {
      "type": "text",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "show_revelation"
            },
            false
          ]
        }
      }
    },
    "show_revelation": {
      "type": "boolean"
    }
  }
}
